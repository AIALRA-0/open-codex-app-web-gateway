# Copy values into /srv/aialra/config/secrets/opencodexapp.env or another
# machine-local secret file. Do not commit real credentials.

CODEXAPP_USERNAME=change-me
CODEXAPP_PASSWORD=change-me
CODEXAPP_SESSION_SECRET=change-me-random-64-hex

DEEPSEEK_API_KEY=change-me
CODEXCOMPAT_PROVIDER_BASE_URL=https://api.deepseek.com
CODEXCOMPAT_PROVIDER_API_KEY_ENV=DEEPSEEK_API_KEY
CODEXCOMPAT_DEFAULT_MODEL=deepseek-v4-pro
CODEXCOMPAT_PORT=12912
CODEXCOMPAT_STATE_DIR=/srv/aialra/apps/open-codex-app-web-gateway/state/responses-bridge
CODEXCOMPAT_CHAT_COMPLETIONS_PATH=/chat/completions
CODEXCOMPAT_MODELS_PATH=/models
CODEXCOMPAT_JSON_SCHEMA_MODE=json_object
CODEXCOMPAT_DEEPSEEK_REASONING_EFFORT_COMPAT=true
CODEXCOMPAT_DEEPSEEK_THINKING_MODE=false
CODEXCOMPAT_DEEPSEEK_DISABLE_THINKING_FOR_TOOL_CHOICE=true
CODEXCOMPAT_COMPACTION_MAX_OUTPUT_TOKENS=512
CODEXCOMPAT_COMPACTION_SECRET_FILE=/srv/aialra/apps/open-codex-app-web-gateway/state/responses-bridge/compaction.key
CODEXCOMPAT_WEB_SEARCH_PROVIDER=wikipedia
CODEXCOMPAT_WEB_SEARCH_MAX_RESULTS=5
CODEXCOMPAT_WEB_SEARCH_TIMEOUT_MS=10000
CODEXCOMPAT_WEB_SEARCH_STATIC_RESULTS=
CODEXCOMPAT_WEB_SEARCH_WIKIPEDIA_ENDPOINT=https://en.wikipedia.org/w/api.php
CODEXCOMPAT_DEEPSEEK_DISABLE_THINKING_FOR_LOCAL_WEB_SEARCH=true
CODEXCOMPAT_FILE_SEARCH_PROVIDER=local
CODEXCOMPAT_FILE_SEARCH_STATE_DIR=/srv/aialra/apps/open-codex-app-web-gateway/state/responses-bridge/local-file-search
CODEXCOMPAT_FILE_SEARCH_MAX_RESULTS=5
CODEXCOMPAT_FILE_SEARCH_MAX_FILE_BYTES=4194304
CODEXCOMPAT_DEEPSEEK_DISABLE_THINKING_FOR_LOCAL_FILE_SEARCH=true

CODEXAPP_WEB_PORT=12920
CODEXAPP_APP_SERVER_PORT=12921
CODEXAPP_STATE_DIR=/srv/aialra/apps/open-codex-app-web-gateway/state
