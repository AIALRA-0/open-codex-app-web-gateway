{
  "name": "open-codex-app-web-gateway",
  "private": true,
  "version": "0.2.0",
  "type": "commonjs",
  "description": "Codex App web gateway plus a Responses API compatibility bridge for OpenAI-compatible Chat Completions providers.",
  "scripts": {
    "start": "node web-server.js",
    "start:bridge": "node src/bridge/server.js",
    "test": "node --test test/*.test.js",
    "eval:protocol": "node scripts/eval-harness.mjs --suite protocol-smoke",
    "eval:bridge": "node scripts/eval-harness.mjs --suite bridge-regression",
    "bench:code": "node scripts/code-benchmark.mjs",
    "smoke:ui": "node scripts/ui-smoke.mjs",
    "smoke:bridge": "node scripts/smoke-test-bridge.mjs",
    "secret-scan": "node scripts/secret-scan.mjs"
  },
  "dependencies": {
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "playwright": "^1.60.0"
  }
}
